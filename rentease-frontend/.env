# ============================================================
# RentEase AI — Environment Variables
# IBM Cloud Student Account Configuration
# ============================================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# ── IBM Cloudant ─────────────────────────────────────────────
# Get these from IBM Cloud > Cloudant > Service Credentials
CLOUDANT_URL=https://YOUR_INSTANCE.cloudantnosqldb.appdomain.cloud
CLOUDANT_API_KEY=your_cloudant_api_key_here

# ── IBM App ID ────────────────────────────────────────────────
# Get these from IBM Cloud > App ID > Applications
APPID_TENANT_ID=your_tenant_id
APPID_CLIENT_ID=your_client_id
APPID_SECRET=your_app_id_secret
APPID_OAUTH_SERVER_URL=https://us-south.appid.cloud.ibm.com/oauth/v4/YOUR_TENANT_ID
APPID_REDIRECT_URI=http://localhost:5173/auth/callback

# ── IBM Watson Assistant ──────────────────────────────────────
# Get these from IBM Cloud > Watson Assistant > API Details
WATSON_ASSISTANT_API_KEY=your_watson_api_key
WATSON_ASSISTANT_URL=https://api.us-south.assistant.watson.cloud.ibm.com
WATSON_ASSISTANT_ID=your_assistant_id
WATSON_INTEGRATION_ID=your_web_chat_integration_id

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_WATSON_INTEGRATION_ID=your_watson_web_chat_integration_id
VITE_WATSON_REGION=us-south
VITE_WATSON_SERVICE_INSTANCE_ID=your_service_instance_id
